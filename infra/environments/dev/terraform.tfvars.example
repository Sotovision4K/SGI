# ================================================
# Terraform Variables — SGI Pro Dev Environment
# ================================================
# Copy this file to terraform.tfvars and fill in your values.
#   cp terraform.tfvars.example terraform.tfvars
#
# terraform.tfvars is gitignored and will NOT be committed.

aws_region     = "us-east-1"
environment    = "dev"
project_name   = "cert-app"

# GitHub repository for OIDC role assumption (format: OWNER/REPO)
github_repository = "OWNER/REPO"

# Anthropic API key for LLM features (sensitive — keep this secret!)
anthropic_api_key = "sk-ant-..."

# Optional: override CORS allowed origins (comma-separated).
# Defaults to the CloudFront domain if available, otherwise localhost:5173,localhost:3000
# cors_allow_origins = "https://my-app.example.com,http://localhost:5173"
