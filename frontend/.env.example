# AWS Cognito Configuration
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=https://us-east-1xxxxxxxxx.auth.us-east-1.amazoncognito.com
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_AUTHORITY=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX

# Redirect URIs (for Cognito callback flows)
VITE_REDIRECT_SIGN_IN=http://localhost:5173/api/v1/process
VITE_REDIRECT_SIGN_OUT=http://localhost:5173/auth/signin
VITE_REDIRECT_URI=http://localhost:5173/

# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# Instructions:
# 1. Copy this file to .env
# 2. Update with your actual AWS Cognito credentials
# 3. NEVER commit .env to version control
# 4. VITE_REDIRECT_URI should be the root path (/) - react-oidc-context handles callbacks
# 5. VITE_REDIRECT_SIGN_IN should point to your main protected route
# 6. VITE_REDIRECT_SIGN_OUT should point to your sign-in page
